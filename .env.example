# ============================
# IntelliAttend Environment Variables
# ============================

# Backend
SECRET_KEY=your-super-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (production)
DB_NAME=intelliattend
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# AI Service
AI_SERVICE_URL=http://localhost:8001

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_AI_URL=http://localhost:8001

# Email (Gmail SMTP)
# Dev: leave EMAIL_BACKEND as console to print emails to terminal
# Prod: set to django.core.mail.backends.smtp.EmailBackend and fill in credentials
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
# Generate App Password at: https://myaccount.google.com/apppasswords (requires 2FA)
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=IntelliAttend <your-gmail@gmail.com>

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:5173
